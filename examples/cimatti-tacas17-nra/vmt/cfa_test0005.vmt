(declare-const k Real)
(declare-const m Real)
(declare-const n Real)
(declare-const x Real)
(declare-const y Real)
(declare-const z Real)
(declare-const S Real)

(declare-const k.next Real)
(declare-const m.next Real)
(declare-const n.next Real)
(declare-const x.next Real)
(declare-const y.next Real)
(declare-const z.next Real)
(declare-const S.next Real)

(define-fun sv.k () Real (! k :next k.next))
(define-fun sv.m () Real (! m :next m.next))
(define-fun sv.n () Real (! n :next n.next))
(define-fun sv.x () Real (! x :next x.next))
(define-fun sv.y () Real (! y :next y.next))
(define-fun sv.z () Real (! z :next z.next))
(define-fun sv.S () Real (! S :next S.next))

(define-fun range ((v Real)) Bool (and (<= (- 10000000) v) (<= v 10000000)))
(define-fun square ((v Real)) Real (* v v))

(define-fun init () Bool
  (! (and
      (= S 0)
      (= k 10.355)
      (= m 5.211)
      (= n (- 56.324))
      (range x)
      (range y)
      (range z)
      )
     :init true))

(define-fun trans () Bool
  (!
   (and
    (range k) (range k.next)
    (range m) (range m.next)
    (range n) (range n.next)
    (range x) (range x.next)
    (range y) (range y.next)
    (range z) (range z.next)
    (or
      (and (= S 0)
           (< n 0)
           (= S.next 1)
           (= z.next (+ (square k) (square m) (square n)))
           (= k.next k)
           (= m.next m)
           (= n.next n)
           (= x.next x)
           (= y.next y)
           )
      (and (= S 1)
           true
           (= S.next 2)
           (= y.next (- z (* 2 (* k m))))
           (= k.next k)
           (= m.next m)
           (= n.next n)
           (= x.next x)
           (= z.next z)
           )
      (and (= S 2)
           true
           (= S.next 3)
           (= x.next (+ (* 3 z) y 34.654))
           (= k.next k)
           (= m.next m)
           (= n.next n)
           (= y.next y)
           (= z.next z)
           )
      (and (= S 3)
           (> m 0)
           (= S.next 3)
           (= m.next (- m 1))
           (= k.next (* k 2))
           (= n.next (+ n 0.5))
           (= x.next x)
           (= y.next y)
           (= z.next z)
           )
      (and (= S 3)
           (<= m 0)
           (= S.next 4)
           (= k.next k)
           (= m.next m)
           (= n.next n)
           (= x.next x)
           (= y.next y)
           (= z.next z)
           )
      (and (= S 4)
           (> z 1000.23)
           (= S.next 5)
           (= z.next (+ z x y))
           (= k.next k)
           (= m.next m)
           (= n.next n)
           (= x.next x)
           (= y.next y)
           )
      (and (= S 4)
           (<= z 1000.23)
           (= S.next 6)
           (= z.next (+ z (- x) (- y)))
           (= k.next k)
           (= m.next m)
           (= n.next n)
           (= x.next x)
           (= y.next y)
           )
      (and (= S 5)
           true
           (= S.next 7)
           (= k.next k)
           (= m.next m)
           (= n.next n)
           (= x.next x)
           (= y.next y)
           (= z.next z)
           )
      (and (= S 6)
           true
           (= S.next 7)
           (= k.next k)
           (= m.next m)
           (= n.next n)
           (= x.next x)
           (= y.next y)
           (= z.next z)
           )
      (and (= S 7)
           true
           (= S.next 8)
           (= k.next k)
           (= m.next m)
           (= n.next n)
           (= x.next x)
           (= y.next y)
           (= z.next z)
           )
      (and (= S 0)
           (>= n 0)
           (= S.next 8)
           (= z.next (+ z 143.223))
           (= k.next k)
           (= m.next m)
           (= n.next n)
           (= x.next x)
           (= y.next y)
           )
      (and (= S 8)
           (< k 5.5)
           (= S.next 9)
           (= y.next (+ (* y 3) 1))
           (= k.next k)
           (= m.next m)
           (= n.next n)
           (= x.next x)
           (= z.next z)
           )
      (and (= S 8)
           (>= k 5.5)
           (= S.next 10)
           (= y.next 1)
           (= k.next k)
           (= m.next m)
           (= n.next n)
           (= x.next x)
           (= z.next z)
           )
      (and (= S 9)
           true
           (= S.next 11)
           (= k.next k)
           (= m.next m)
           (= n.next n)
           (= x.next x)
           (= y.next y)
           (= z.next z)
           )
      (and (= S 10)
           true
           (= S.next 11)
           (= k.next k)
           (= m.next m)
           (= n.next n)
           (= x.next x)
           (= y.next y)
           (= z.next z)
           )
      (and (= S 11)
           (= x y)
           (= S.next 12)
           (= z.next 1)
           (= k.next k)
           (= m.next m)
           (= n.next n)
           (= x.next x)
           (= y.next y)
           )
      (and (= S 11)
           (not (= x y))
           (= S.next 13)
           (= z.next (- 1))
           (= k.next k)
           (= m.next m)
           (= n.next n)
           (= x.next x)
           (= y.next y)
           )
      )
    )
   :trans true))

(define-fun prop () Bool (! (not (= S 13)) :invar-property 0))
