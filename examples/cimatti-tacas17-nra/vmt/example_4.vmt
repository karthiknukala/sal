(declare-const x Real)
(declare-const y Real)
(declare-const z Real)
(declare-const i Real)
(declare-const x.next Real)
(declare-const y.next Real)
(declare-const z.next Real)
(declare-const i.next Real)

(define-fun sv.x () Real (! x :next x.next))
(define-fun sv.y () Real (! y :next y.next))
(define-fun sv.z () Real (! z :next z.next))
(define-fun sv.i () Real (! i :next i.next))

(define-fun init () Bool (! (and (>= x 2)
                                 (>= y 2)
                                 (= z (* x y))
                                 (= i 0)) :init true))
(define-fun trans () Bool (! (and (= x.next (+ x 1))
                                  (= y.next (+ y 1))
                                  (= i.next (+ i 1))
                                  (=> (<= i 4) (= z.next (* x.next y.next))))
                             :trans true))
(define-fun prop () Bool (! (>= z (+ x y)) :invar-property 0))
