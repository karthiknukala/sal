(declare-const x Real)
(declare-const y Real)
(declare-const z Real)
(declare-const S Real)

(declare-const x.next Real)
(declare-const y.next Real)
(declare-const z.next Real)
(declare-const S.next Real)

(define-fun sv.x () Real (! x :next x.next))
(define-fun sv.y () Real (! y :next y.next))
(define-fun sv.z () Real (! z :next z.next))
(define-fun sv.S () Real (! S :next S.next))

(define-fun init () Bool
  (! (and
      (= S 0)
      (= x 12)
      (= y 15.45)
      (= z (+ x 12.654))
      )
     :init true))

(define-fun trans () Bool
  (!
   (and
    (<= (- 1000000) x) (<= x 1000000)
    (<= (- 1000000) y) (<= y 1000000)
    (<= (- 1000000) z) (<= z 1000000)
    (<= (- 1000000) x.next) (<= x.next 1000000)
    (<= (- 1000000) y.next) (<= y.next 1000000)
    (<= (- 1000000) z.next) (<= z.next 1000000)
    (or
      (and (= S 0)
           (> z 100)
           (= S.next 1)
           (= y.next (+ x z))
           (= x.next x)
           (= z.next z))
      (and (= S 1)
           (< y 32)
           (= S.next 2)
           (= z.next (* 23.45 (* x y)))
           (= x.next (+ x 1))
           (= y.next y))
      (and (= S 2)
           (= x 0)
           (= S.next 3)
           (= y.next (+ x z (- 50)))
           (= x.next x)
           (= z.next z))
      (and (= S 2)
           (not (= x 0))
           (= S.next 4)
           (= y.next 5)
           (= x.next x)
           (= z.next z))
      (and (= S 4)
           (> y 1)
           (= S.next 5)
           (= z.next (* 2 y))
           (= y.next y)
           (= x.next x))
      (and (= S 4)
           (<= y 1)
           (= S.next 6)
           (= x.next 1234.3)
           (= y.next y)
           (= z.next z))
      (and (= S 3)
           (= S.next 10)
           (= x.next x)
           (= y.next y)
           (= z.next z))
      (and (= S 5)
           (= S.next 10)
           (= x.next x)
           (= y.next y)
           (= z.next z))
      (and (= S 6)
           (= S.next 10)
           (= x.next x)
           (= y.next y)
           (= z.next z))
      (and (= S 1)
           (>= y 32)
           (= S.next 7)
           (= z.next (* x y))
           (= y.next y)
           (= x.next x))
      (and (= S 0)
           (<= z 100)
           (= S.next 8)
           (= z.next (+ z 43.3))
           (= y.next y)
           (= x.next x))
      (and (= S 7)
           (= S.next 9)
           (= x.next x)
           (= y.next y)
           (= z.next z))
      (and (= S 8)
           (= S.next 9)
           (= x.next x)
           (= y.next y)
           (= z.next z))
      (and (= S 9)
           (= S.next 10)
           (= x.next (* z (* z z)))
           (= y.next y)
           (= z.next z))
      (and (= S 10)
           (= z 0)
           (= S.next 11)
           (= z.next 5)
           (= x.next x)
           (= y.next y))
      (and (= S 10)
           (not (= z 0))
           (= S.next 12)
           (= z.next (- 5))
           (= x.next x)
           (= y.next y))
      ))
     :trans true))

(define-fun prop () Bool (! (not (= S 11)) :invar-property 0))
