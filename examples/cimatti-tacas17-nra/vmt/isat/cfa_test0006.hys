----------------------------------------------------
-- This case is borrowed from Nim's master thesis --
-- p. 78                                          --
-- where the specification is NOT REACHABLE       --
-- Problem is polynomial						  --
----------------------------------------------------

DECL
float [-10000000,10000000] x,y,z;


NODES
S0,S1,S2,S3,S4,S5,S6,S7,S8,S9,S10,S11,S12;

INIT
edge(true, 
     {x= 12 && y= 15.45 && z = x + 12.654}, 
     {true}, 
     S0);


FLOWS
edge(S0,  {z>100} ,{y'= x+z}             , S1');
edge(S1,  {y<32}  ,{z'=23.45*x*y, x'=x+1}, S2');
edge(S2,  {x=0}   ,{y'=x+z-50}           , S3');
edge(S2,  {x!=0}  ,{y'=5}                , S4');
edge(S4,  {y>1}   ,{z'=2*y}              , S5');
edge(S4,  {y<=1}  ,{x'=1234.3}           , S6');
edge(S3,  {}      ,{}                    , S10');
edge(S5,  {}      ,{}                    , S10');
edge(S6,  {}      ,{}                    , S10');
edge(S1,  {y>=32} ,{z'=x*y}              , S7');
edge(S0,  {z<=100},{z'=z+43.3}           , S8');
edge(S7,  {}      ,{}                    , S9');
edge(S8,  {}      ,{}                    , S9');
edge(S9,  {true}  ,{x'=z^3}              , S10');
edge(S10, {z=0}   ,{z'=5}                , S11');
edge(S10, {z!=0}  ,{z'=-5}               , S12');

SPECIFICATION
S11;

