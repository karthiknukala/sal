(define-fun a () Real 1.25)
(define-fun b () Real 0.3)

(declare-const x Real)
(declare-const y Real)
(declare-const S Real)

(declare-const x.next Real)
(declare-const y.next Real)
(declare-const S.next Real)

(define-fun sv.x () Real (! x :next x.next))
(define-fun sv.y () Real (! y :next y.next))
(define-fun sv.S () Real (! S :next S.next))

(define-fun range () Bool
  (and (<= (- 100) y) (<= y 100)
       (<= (- 100) x) (<= x 100)
       ))
(define-fun range.next () Bool
  (and (<= (- 100) y.next) (<= y.next 100)
       (<= (- 100) x.next) (<= x.next 100)
       ))
(define-fun square ((v Real)) Real (* v v))

(define-fun init () Bool
  (! (and
      (= S 0)
      (= x (- 1.09))
      (= y 0.386)
      range
      )
     :init true))

(define-fun trans () Bool
  (!
   (and
    range
    range.next
    (or
      (and (= S 0)
           true
           (= S.next 0)
           (= x.next (+ y 1 (* (- a) (square x))))
           (= y.next y))
      (and (= S 1)
           true
           (= S.next 0)
           (= y.next (* b x))
           (= x.next x))
      (and (= S 0)
           (not
            (or
             (and (>= x 1.263) (<= x 1.313))
             (and (>= x (- 1.115)) (<= x (- 1.065)))
             (and (>= x (- 0.124)) (<= x (- 0.074)))
             (and (>= x 0.636) (<= x 0.686))
             (and (>= x 0.400) (<= x 0.450))
             (and (>= x 0.948) (<= x 0.998))
             (and (>= x (- 0.080)) (<= x (- 0.030)))))
           (= S.next 2)
           (= x.next x)
           (= y.next y)
           )
      )
    )
   :trans true))

(define-fun prop () Bool (! (not (= S 2)) :invar-property 0))
