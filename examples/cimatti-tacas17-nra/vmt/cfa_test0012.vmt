(define-fun car_inertia () Real 2000)
(define-fun car_face () Real 2)
(define-fun cw_factor () Real 1.11)
(define-fun air_density () Real 1.204)
(define-fun dt () Real 0.01)
(define-fun velocity_to_hold () Real 10)
(define-fun delta_update_interval () Real 1)
(define-fun update_interval () Real 3)

(declare-const car_velocity Real)
(declare-const car_velocity.next Real)
(define-fun sv.car_velocity () Real (! car_velocity :next car_velocity.next))

(declare-const car_acc_interaction Real)
(declare-const car_acc_interaction.next Real)
(define-fun sv.car_acc_interaction () Real (! car_acc_interaction :next car_acc_interaction.next))

(declare-const res_acc_interaction Real)
(declare-const res_acc_interaction.next Real)
(define-fun sv.res_acc_interaction () Real (! res_acc_interaction :next res_acc_interaction.next))

(declare-const acc Real)
(declare-const acc.next Real)
(define-fun sv.acc () Real (! acc :next acc.next))

(declare-const update_counter Real)
(declare-const update_counter.next Real)
(define-fun sv.update_counter () Real (! update_counter :next update_counter.next))

(declare-const S Real)
(declare-const S.next Real)
(define-fun sv.S () Real (! S :next S.next))

(define-fun range () Bool
  (and
   (<= (- 10000) car_velocity) (<= car_velocity 10000)
   (<= (- 10000) car_acc_interaction) (<= car_acc_interaction 10000)
   (<= (- 10000) res_acc_interaction) (<= res_acc_interaction 10000)
   (<= (- 300000) acc) (<= acc 300000)
   (<= 0 update_counter) (<= update_counter 100)))

(define-fun range.next () Bool
  (and
   (<= (- 10000) car_velocity.next) (<= car_velocity.next 10000)
   (<= (- 10000) car_acc_interaction.next) (<= car_acc_interaction.next 10000)
   (<= (- 10000) res_acc_interaction.next) (<= res_acc_interaction.next 10000)
   (<= (- 300000) acc.next) (<= acc.next 300000)
   (<= 0 update_counter.next) (<= update_counter.next 100)))

(define-fun square ((v Real)) Real (* v v))

(define-fun init () Bool
  (! (and
      (= update_counter 0)
      (= car_velocity velocity_to_hold)
      (= car_acc_interaction 1000)
      (= car_acc_interaction (* acc car_inertia))
      (= res_acc_interaction car_acc_interaction)
      (= S 0)
      )
     :init true))

(define-fun trans () Bool
  (!
   (and
    range range.next
    (or
      (and (= S 0)
           (>= update_counter update_interval)
           (= S.next 1)
           (= car_acc_interaction.next car_acc_interaction)
           (= res_acc_interaction.next (- car_acc_interaction (* car_face (* cw_factor (* air_density (* 0.5 (square car_velocity)))))))
           (= update_counter.next (+ update_counter delta_update_interval))
           (= car_velocity.next (+ car_velocity (* acc dt)))
           (= acc.next acc)
           )
      (and (= S 1)
           true
           (= S.next 2)
           (= acc.next (/ res_acc_interaction car_inertia))
           (= car_velocity.next car_velocity)
           (= car_acc_interaction.next car_acc_interaction)
           (= res_acc_interaction.next res_acc_interaction)
           (= update_counter.next update_counter)
           )
      (and (= S 0)
           (and (< update_counter update_interval)
                (> car_velocity velocity_to_hold))
           (= S.next 3)
           (= update_counter.next 0)
           (= car_velocity.next 0)
           (= res_acc_interaction.next res_acc_interaction)
           (= car_acc_interaction.next 0)
           (= acc.next acc)
           )
      (and (= S 0)
           (and (< update_counter update_interval)
                (>= car_velocity velocity_to_hold))
           (= S.next 4)
           (= update_counter.next 0)
           (= car_velocity.next car_velocity)
           (= res_acc_interaction.next res_acc_interaction)
           (= car_acc_interaction.next 1000)
           (= acc.next acc)
           )
      (and (= S 0)
           true
           (= S.next 5)
           ;; this set of constraints seems to be trivially inconsistent.
           ;; If I comment out the duplicate updates (the lines until END), then
           ;; the property becomes false (tested also with Z3 bmc)
           (= update_counter.next 0)
           (= car_velocity.next car_velocity)
           (= res_acc_interaction.next res_acc_interaction)
           (= car_acc_interaction.next 0)
           ;; END
           (= acc.next acc)
           (= car_acc_interaction.next car_acc_interaction)
           (= res_acc_interaction.next (- car_acc_interaction (* car_face (* cw_factor (* air_density (* 0.5 (square car_velocity)))))))
           (= update_counter.next (+ update_counter delta_update_interval))
           (= car_velocity.next (+ car_velocity (* acc dt)))
           )
      (and (= S 5)
           true
           (= S.next 6)
           (= acc.next (/ res_acc_interaction car_inertia))
           (= car_velocity.next car_velocity)
           (= car_acc_interaction.next car_acc_interaction)
           (= res_acc_interaction.next res_acc_interaction)
           (= update_counter.next update_counter)
           )
      (and (= S 2)
           (or (< car_velocity 9.8) (> car_velocity 10.2))
           (= S.next 7)
           (= acc.next acc)
           (= car_velocity.next car_velocity)
           (= car_acc_interaction.next car_acc_interaction)
           (= res_acc_interaction.next res_acc_interaction)
           (= update_counter.next update_counter)
           )
      (and (= S 2)
           (and (>= car_velocity 9.8) (<= car_velocity 10.2))
           (= S.next 0)
           (= acc.next acc)
           (= car_velocity.next car_velocity)
           (= car_acc_interaction.next car_acc_interaction)
           (= res_acc_interaction.next res_acc_interaction)
           (= update_counter.next update_counter)
           )
      (and (= S 3)
           (or (< car_velocity 9.8) (> car_velocity 10.2))
           (= S.next 7)
           (= acc.next acc)
           (= car_velocity.next car_velocity)
           (= car_acc_interaction.next car_acc_interaction)
           (= res_acc_interaction.next res_acc_interaction)
           (= update_counter.next update_counter)
           )
      (and (= S 3)
           (and (>= car_velocity 9.8) (<= car_velocity 10.2))
           (= S.next 0)
           (= acc.next acc)
           (= car_velocity.next car_velocity)
           (= car_acc_interaction.next car_acc_interaction)
           (= res_acc_interaction.next res_acc_interaction)
           (= update_counter.next update_counter)
           )
      (and (= S 4)
           (or (< car_velocity 9.8) (> car_velocity 10.2))
           (= S.next 7)
           (= acc.next acc)
           (= car_velocity.next car_velocity)
           (= car_acc_interaction.next car_acc_interaction)
           (= res_acc_interaction.next res_acc_interaction)
           (= update_counter.next update_counter)
           )
      (and (= S 4)
           (and (>= car_velocity 9.8) (<= car_velocity 10.2))
           (= S.next 0)
           (= acc.next acc)
           (= car_velocity.next car_velocity)
           (= car_acc_interaction.next car_acc_interaction)
           (= res_acc_interaction.next res_acc_interaction)
           (= update_counter.next update_counter)
           )
      (and (= S 6)
           (or (< car_velocity 9.8) (> car_velocity 10.2))
           (= S.next 7)
           (= acc.next acc)
           (= car_velocity.next car_velocity)
           (= car_acc_interaction.next car_acc_interaction)
           (= res_acc_interaction.next res_acc_interaction)
           (= update_counter.next update_counter)
           )
      (and (= S 6)
           (and (>= car_velocity 9.8) (<= car_velocity 10.2))
           (= S.next 0)
           (= acc.next acc)
           (= car_velocity.next car_velocity)
           (= car_acc_interaction.next car_acc_interaction)
           (= res_acc_interaction.next res_acc_interaction)
           (= update_counter.next update_counter)
           )
      )
    )
   :trans true))

(define-fun prop () Bool (! (not (= S 7)) :invar-property 0))
