(declare-const a Real)
(declare-const b Real)
(declare-const x Real)
(declare-const y Real)
(declare-const S Real)

(declare-const a.next Real)
(declare-const b.next Real)
(declare-const x.next Real)
(declare-const y.next Real)
(declare-const S.next Real)

(define-fun sv.a () Real (! a :next a.next))
(define-fun sv.b () Real (! b :next b.next))
(define-fun sv.x () Real (! x :next x.next))
(define-fun sv.y () Real (! y :next y.next))
(define-fun sv.S () Real (! S :next S.next))

(define-fun r1 () Real 100)
(define-fun r1_jitter () Real 8000)
(define-fun r2 () Real 10000)

(define-fun square ((v Real)) Real (* v v))

(define-fun init () Bool
  (! (and
      (= S 0)
      (= a 1)
      (= (* a b) r1_jitter)
      (<= (+ (square (+ x 0.5)) (square (+ y 0.5))) (square (+ r1 b)))
      (<= (- 1000000) x) (<= x 1000000)
      (<= (- 1000000) y) (<= y 1000000)
      )
     :init true))

(define-fun trans () Bool
  (!
   (and
    (<= (- 1000000) a) (<= a 1000000)
    (<= (- 1000000) b) (<= b 1000000)
    (<= (- 1000000) x) (<= x 1000000)
    (<= (- 1000000) y) (<= y 1000000)
    (<= (- 1000000) a.next) (<= a.next 1000000)
    (<= (- 1000000) b.next) (<= b.next 1000000)
    (<= (- 1000000) x.next) (<= x.next 1000000)
    (<= (- 1000000) y.next) (<= y.next 1000000)
    (or
      (and (= S 0)
           (<= (+ (square (+ x 0.5)) (square (+ y 0.5))) (square (+ r1 b)))
           (= S.next 1)
           (= a.next (+ a 1))
           (= b.next b)
           (= x.next x)
           (= y.next y)
           )
      (and (= S 1)
           (<= (+ (square (+ x 0.5)) (square (+ y 0.5))) (square (+ r1 b)))
           (= S.next 2)
           (= a.next a)
           (= b.next b)
           (= x.next x)
           (= y.next y)
           )
      (and (= S 2)
           (<= (+ (square (+ x 0.5)) (square (+ y 0.5))) (square (+ r1 b)))
           (= S.next 3)
           (= a.next a)
           (= b.next b)
           (= x.next x)
           (= y.next y)
           )
      (and (= S 3)
           (and (= (* a b) r1_jitter)
                (<= (+ (square (+ x 0.5)) (square (+ y 0.5))) (square (+ r1 b))))
           (= S.next 4)
           (= a.next a)
           (= b.next b)
           (= x.next x)
           (= y.next y)
           )
      (and (= S 4)
           (>= (+ (square (+ x 1)) (square (+ y 1))) (square r2))
           (= S.next 5)
           (= a.next a)
           (= b.next b)
           (= x.next x)
           (= y.next y)
           )
      (and (= S 4)
           (< (+ (square (+ x 1)) (square (+ y 1))) (square r2))
           (= S.next 0)
           (= a.next a)
           (= b.next b)
           (= x.next x)
           (= y.next y)
           )
      ))
     :trans true))

(define-fun prop () Bool (! (not (= S 5)) :invar-property 0))
